# ─────────────────────────────────────────────
# BusScanner Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Set to true to use realistic mock data (no API keys needed)
# Set to false when you have real API credentials
DEMO_MODE=true

# ─── RedBus / SeatSeller API ─────────────────
# Get access: email b2b@redbus.in or visit seatseller.travel
# After B2B approval (~2-4 weeks), you receive these:
REDBUS_BASE_URL=https://api.seatseller.travel
REDBUS_API_KEY=YOUR_SEATSELLER_API_KEY_HERE

# ─── AbhiBus API ─────────────────────────────
# Get access: email techsupport@abhibus.com
# After B2B approval, you receive these:
ABHIBUS_BASE_URL=https://api.abhibus.com/ws
ABHIBUS_USERNAME=YOUR_ABHIBUS_USERNAME
ABHIBUS_PASSWORD=YOUR_ABHIBUS_PASSWORD
ABHIBUS_API_KEY=YOUR_ABHIBUS_API_KEY

# ─── Cache (optional) ────────────────────────
# Falls back to in-memory cache if Redis not available
REDIS_URL=redis://localhost:6379
CACHE_TTL_SEARCH=300
CACHE_TTL_CITIES=86400

# ─── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:3001
